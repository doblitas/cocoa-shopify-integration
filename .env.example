# Solo integración de productos (API Cocoa documentada). Un objeto por tienda Shopify.
# JSON array with one object per Shopify store (tenant)
SHOPIFY_TENANTS_JSON=[{"tenantId":"cocoa_bo","shopDomain":"my-store-bolivia.myshopify.com","webhookSecret":"replace_me","adminAccessToken":"replace_me","cocoa":{"baseUrl":"app-z3gjk55rwa-uc.a.run.app","user":"1234","password":"1234"},"defaultCategoryKey":"dEDtC5EoKxdtwHqIhi8a","categoryMap":{"lo mas vendido":"dEDtC5EoKxdtwHqIhi8a","unico en tu tienda":"pEfPrAFQ4O569IEOjCsd","otros":"rpRif5eUwaxCr1AT6aD6","lo nuevo":"rxC6t41HWRt8ddM1Hjzk"}}]

# Optional but recommended for persistent cross-deployment mappings
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bulk sync (POST /api/sync/products): optional shared secret for curl/CI — send Bearer + ?tenantId=...
# If unset, the endpoint still works with a valid Shopify session JWT (embedded admin or scripts using a token).
SYNC_SECRET=generate_a_long_random_string

# Embedded admin UI (/dashboard): required for "Actualizar" / session auth + "Sincronizar todo" via JWT
# Client ID + Client secret from Partners (same custom app as store installation)
NEXT_PUBLIC_SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# OAuth (GET /api/auth?shop=... y Redirect URL /api/auth/callback en Shopify). Opcional; por defecto read/write productos + inventario
# SHOPIFY_APP_SCOPES=read_products,write_products,read_inventory

# Optional: hostname of this app without scheme (defaults to VERCEL_URL in production)
# SHOPIFY_APP_HOST=cocoa-shopify-integration.vercel.app

# Shopify Admin API version for sync (default 2024-10 if unset)
# SHOPIFY_ADMIN_API_VERSION=2024-10
